# Python
**/__pycache__/
*.py[cod]
*$py.class
**/.pytest_cache/
**/.mypy_cache/
.ruff_cache/

# Virtual environments
**/.venv/
.venv-build/
**/venv/
env/

# Node / web build
**/node_modules/
**/.next/

# Build output
**/build/
**/dist/
*.spec.bak

# Coverage
**/coverage/

# Local runtime files
settings.json
bases.json
armies.json
cocbot.log
*.log
debug/
screenshots/

# Local release artifacts
release/
*.zip
*.sha256

# Binary / large artifacts (already-tracked files remain tracked)
*.exe
*.dll
*.pyd
*.sqlite
*.db
*.mp4

# Image artifacts — debug screenshots etc.
# (NOTE: PNG/JPG already tracked under templates/ & root stay tracked;
#  this only blocks NEW untracked images. Use `git add -f` to force.)
*.png
*.jpg
*.jpeg
*.webp

# Secrets / env
.env
.env.*
*.local

# Editor / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db
